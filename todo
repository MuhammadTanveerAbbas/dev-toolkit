#!/bin/bash
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; MAGENTA='\033[0;35m'; BOLD='\033[1m'; DIM='\033[2m'; RESET='\033[0m'

TODO_FILE="$HOME/.dev-toolkit-data/todos.txt"
mkdir -p "$HOME/.dev-toolkit-data"
[ ! -f "$TODO_FILE" ] && touch "$TODO_FILE"

print_banner() {
  echo -e "${MAGENTA}${BOLD}"
  echo "  ████████╗ ██████╗ ██████╗  ██████╗ "
  echo "  ╚══██╔══╝██╔═══██╗██╔══██╗██╔═══██╗"
  echo "     ██║   ██║   ██║██║  ██║██║   ██║"
  echo "     ██║   ██║   ██║██║  ██║██║   ██║"
  echo "     ██║   ╚██████╔╝██████╔╝╚██████╔╝"
  echo "     ╚═╝    ╚═════╝ ╚═════╝  ╚═════╝ "
  echo -e "${RESET}"
  echo -e "  ${BOLD}  Todo — Persistent task list that lives in your terminal${RESET}"
  echo -e "  ${DIM}  themvpguy.vercel.app${RESET}"
  echo -e "  ${DIM}  ──────────────────────────────────────────────────────────${RESET}\n"
}

show_todos() {
  local total done_count pending_count
  total=$(wc -l < "$TODO_FILE" 2>/dev/null); total=${total:-0}
  done_count=$(grep -c "^\[x\]" "$TODO_FILE" 2>/dev/null); done_count=${done_count:-0}
  pending_count=$(grep -c "^\[ \]" "$TODO_FILE" 2>/dev/null); pending_count=${pending_count:-0}

  echo -e "  ${BOLD}  Your Tasks${RESET}  ${DIM}($pending_count pending / $done_count done)${RESET}\n"

  if [ "$total" -eq 0 ] || [ ! -s "$TODO_FILE" ]; then
    echo -e "  ${DIM}  No tasks yet. Add one with [1].${RESET}\n"
    return
  fi

  local i=1
  while IFS= read -r line || [ -n "$line" ]; do
    [ -z "$line" ] && continue
    if [[ "$line" == "[x]"* ]]; then
      local task="${line:3}"
      echo -e "  ${DIM}[$i] ✓ $task${RESET}"
    else
      local task="${line:3}"
      echo -e "  ${GREEN}[$i]${RESET} ${BOLD}$task${RESET}"
    fi
    i=$(( i + 1 ))
  done < "$TODO_FILE"
  echo ""
}

add_task() {
  echo -ne "  ${BOLD}New task: ${RESET}"
  read -r TASK
  [ -z "$TASK" ] && echo -e "  ${CYAN}  Nothing added.${RESET}" && return
  echo "[ ] $TASK" >> "$TODO_FILE"
  echo -e "  ${GREEN}✓ Added: $TASK${RESET}\n"
}

complete_task() {
  show_todos
  echo -ne "  ${BOLD}Enter task number to mark done: ${RESET}"
  read -r NUM; NUM="${NUM//[^0-9]/}"
  [ -z "$NUM" ] && return
  local i=1 found=0
  local tmpfile; tmpfile=$(mktemp)
  while IFS= read -r line || [ -n "$line" ]; do
    [ -z "$line" ] && continue
    if [ "$i" = "$NUM" ] && [[ "$line" == "[ ]"* ]]; then
      echo "[x]${line:3}" >> "$tmpfile"
      found=1
    else
      echo "$line" >> "$tmpfile"
    fi
    i=$(( i + 1 ))
  done < "$TODO_FILE"
  mv "$tmpfile" "$TODO_FILE"
  if [ "$found" -eq 1 ]; then
    echo -e "  ${GREEN}✓ Task $NUM marked done.${RESET}\n"
  else
    echo -e "  ${YELLOW}  Task $NUM not found or already done.${RESET}\n"
  fi
}

delete_task() {
  show_todos
  echo -ne "  ${BOLD}Enter task number to delete: ${RESET}"
  read -r NUM; NUM="${NUM//[^0-9]/}"
  [ -z "$NUM" ] && return
  local i=1 tmpfile; tmpfile=$(mktemp)
  while IFS= read -r line || [ -n "$line" ]; do
    [ -z "$line" ] && continue
    [ "$i" != "$NUM" ] && echo "$line" >> "$tmpfile"
    i=$(( i + 1 ))
  done < "$TODO_FILE"
  mv "$tmpfile" "$TODO_FILE"
  echo -e "  ${GREEN}✓ Task $NUM deleted.${RESET}\n"
}

clear_done() {
  local tmpfile; tmpfile=$(mktemp)
  grep "^\[ \]" "$TODO_FILE" 2>/dev/null > "$tmpfile" || true
  mv "$tmpfile" "$TODO_FILE"
  echo -e "  ${GREEN}✓ All completed tasks cleared.${RESET}\n"
}

clear_all() {
  echo -ne "  ${RED}Clear ALL tasks? (y/n): ${RESET}"
  read -r C; C="${C//[^yYnN]/}"
  if [[ "$C" =~ ^[yY]$ ]]; then
    > "$TODO_FILE"
    echo -e "  ${GREEN}✓ All tasks cleared.${RESET}\n"
  else
    echo -e "  ${CYAN}  Cancelled.${RESET}\n"
  fi
}

while true; do
  clear
  print_banner
  show_todos
  echo -e "  ${CYAN}[1]${RESET} Add new task"
  echo -e "  ${CYAN}[2]${RESET} Mark task as done"
  echo -e "  ${CYAN}[3]${RESET} Delete a task"
  echo -e "  ${CYAN}[4]${RESET} Clear completed tasks"
  echo -e "  ${CYAN}[5]${RESET} Clear ALL tasks"
  echo -e "  ${CYAN}[0]${RESET} Exit\n"
  echo -ne "  ${BOLD}Your choice: ${RESET}"
  read -r C; C="${C//[^0-9]/}"
  echo ""
  case "$C" in
    1) add_task ;;
    2) complete_task ;;
    3) delete_task ;;
    4) clear_done ;;
    5) clear_all ;;
    0) echo -e "  ${CYAN}  Stay on top of it, Tanveer. Bye.${RESET}\n"; exit 0 ;;
    *) echo -e "  ${RED}  Invalid.${RESET}"; sleep 1 ;;
  esac
  echo -ne "  ${DIM}Press Enter to continue...${RESET}"; read -r _P
done
