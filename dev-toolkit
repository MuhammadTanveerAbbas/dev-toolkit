#!/bin/bash

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; BLUE='\033[0;34m'; MAGENTA='\033[0;35m'
BOLD='\033[1m'; DIM='\033[2m'; RESET='\033[0m'

DATA_DIR="$HOME/.dev-toolkit-data"
NOTES_DIR="$DATA_DIR/notes"
USAGE_FILE="$DATA_DIR/usage"
LAST_USED_FILE="$DATA_DIR/last_used"
mkdir -p "$DATA_DIR" "$NOTES_DIR" 2>/dev/null || true
[ ! -f "$USAGE_FILE" ] && touch "$USAGE_FILE"
[ ! -f "$LAST_USED_FILE" ] && touch "$LAST_USED_FILE"

# ── OS Detection ─────────────────────────────────────────────────────────
detect_os() {
  if [[ "$OSTYPE" == "msys" ]] || [[ "$OSTYPE" == "cygwin" ]] || [[ -n "$WINDIR" ]]; then
    OS="windows"
  elif [[ "$OSTYPE" == "darwin"* ]]; then
    OS="macos"
  else
    OS="linux"
  fi
}
detect_os

# ── Dynamic Path Resolution ──────────────────────────────────────────────
resolve_tool_path() {
  local cmd="$1"
  local found
  found=$(command -v "$cmd" 2>/dev/null)
  if [ -n "$found" ]; then
    echo "$found"
    return
  fi
  local fallbacks=(
    "/usr/local/bin/$cmd"
    "/usr/bin/$cmd"
    "$HOME/.local/bin/$cmd"
    "$HOME/bin/$cmd"
    "$HOME/.npm-global/bin/$cmd"
  )
  for path in "${fallbacks[@]}"; do
    [ -f "$path" ] && echo "$path" && return
  done
  echo ""
}

is_installed() {
  local cmd="$1"
  [ -n "$(resolve_tool_path "$cmd")" ]
}

# ── Cross-Platform Helpers ──────────────────────────────────────────────
open_url() {
  local url="$1"
  if [ "$OS" = "linux" ]; then
    xdg-open "$url" 2>/dev/null || echo -e "  ${DIM}  Visit: $url${RESET}"
  elif [ "$OS" = "macos" ]; then
    open "$url" 2>/dev/null || echo -e "  ${DIM}  Visit: $url${RESET}"
  elif [ "$OS" = "windows" ]; then
    cmd //c "start $url" 2>/dev/null || echo -e "  ${DIM}  Visit: $url${RESET}"
  fi
}

safe_sed_inplace() {
  local pattern="$1" file="$2"
  if [ "$OS" = "macos" ]; then
    sed -i '' "$pattern" "$file"
  else
    sed -i "$pattern" "$file"
  fi
}

