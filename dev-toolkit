# ── Utility Functions ───────────────────────────────────────────────────
parse_tool() {
  local entry="$1" field="$2"
  local count
  count=$(echo "$entry" | awk -F'|' '{print NF}')
  if [ "$field" -gt "$count" ]; then
    echo ""
    return
  fi
  echo "$entry" | cut -d'|' -f"$field"
}

get_usage()    { grep "^${1}=" "$USAGE_FILE" 2>/dev/null | cut -d= -f2; }
get_last_used(){ cat "$LAST_USED_FILE" 2>/dev/null || echo "none"; }
get_note()     { local f="$NOTES_DIR/${1}.txt"; [ -f "$f" ] && cat "$f" || echo ""; }
save_note()    { echo "$2" > "$NOTES_DIR/${1}.txt"; }
sep()          { echo -e "  ${DIM}──────────────────────────────────────────────────${RESET}"; }
pause()        { echo ""; echo -ne "  ${DIM}Press Enter to go back...${RESET}"; read -r _P; }

track_usage() {
  local tool=$1 count
  count=$(grep "^${tool}=" "$USAGE_FILE" 2>/dev/null | cut -d= -f2)
  count=$(( ${count:-0} + 1 ))
  if grep -q "^${tool}=" "$USAGE_FILE" 2>/dev/null; then
    safe_sed_inplace "s/^${tool}=.*/${tool}=${count}/" "$USAGE_FILE"
  else
    echo "${tool}=${count}" >> "$USAGE_FILE"
  fi
  echo "$tool" > "$LAST_USED_FILE"
}

draw_bar() {
  local pct=$1 width=${2:-20} color=$GREEN bar="" filled empty
  [ "$pct" -ge 60 ] && color=$YELLOW
  [ "$pct" -ge 80 ] && color=$RED
  [ "$pct" -gt 100 ] && pct=100
  filled=$(( pct * width / 100 ))
  empty=$(( width - filled ))
  for ((i=0;i<filled;i++)); do bar+="█"; done
  for ((i=0;i<empty;i++));  do bar+="░"; done
  printf "${color}%s${RESET}" "$bar"
}

