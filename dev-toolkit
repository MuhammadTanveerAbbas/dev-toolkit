      echo -e "  ${YELLOW}${BOLD}  $name${RESET}"
      echo -e "  ${DIM}  → $note${RESET}\n"
      has=1
    fi
  done
  [ "$has" -eq 0 ] && echo -e "  ${DIM}  No notes yet. Select a tool → [5] to save one.${RESET}"
  echo ""; pause
}

show_stats() {
  clear; echo ""
  echo -e "  ${BLUE}${BOLD}╔══════════════════════════════════════════════════════╗${RESET}"
  echo -e "  ${BLUE}${BOLD}║  USAGE STATISTICS                                    ║${RESET}"
  echo -e "  ${BLUE}${BOLD}╚══════════════════════════════════════════════════════╝${RESET}"
  echo -e "  ${DIM}  Launches tracked across all sessions${RESET}\n"
  local any=0 max=1
  for entry in "${TOOLS[@]}"; do
    local c; c=$(get_usage "$(parse_tool "$entry" 1)"); c=${c:-0}
    [ "$c" -gt "$max" ] && max=$c
  done
  for entry in "${TOOLS[@]}"; do
    local name count bars bar=""
    name=$(parse_tool "$entry" 1)
    count=$(get_usage "$name"); count=${count:-0}
    if [ "$count" -gt 0 ]; then
      bars=$(( count * 22 / max ))
      for ((i=0;i<bars;i++)); do bar+="█"; done
      printf "  ${CYAN}  %-18s${RESET} ${GREEN}%-24s${RESET} ${BOLD}%dx${RESET}\n" "$name" "$bar" "$count"
      any=1
    fi
  done
  [ "$any" -eq 0 ] && echo -e "  ${DIM}  No data yet. Launch tools and check back.${RESET}"
  echo ""
  echo -e "  ${YELLOW}  Last used: ${BOLD}$(get_last_used)${RESET}\n"
  pause
}

quick_actions() {
  clear; echo ""
  echo -e "  ${YELLOW}${BOLD}╔══════════════════════════════════════════════════════╗${RESET}"
  echo -e "  ${YELLOW}${BOLD}║  QUICK ACTIONS                                       ║${RESET}"
  echo -e "  ${YELLOW}${BOLD}╚══════════════════════════════════════════════════════╝${RESET}"
  echo -e "  ${DIM}  One-tap shortcuts for your most common tasks${RESET}\n"
  echo -e "  ${CYAN}[1]${RESET} ${BOLD}Kill port 3000${RESET}             ${DIM}Free Next.js default port instantly${RESET}"
  echo -e "  ${CYAN}[2]${RESET} ${BOLD}Git status${RESET}                 ${DIM}Show git status in current directory${RESET}"
  echo -e "  ${CYAN}[3]${RESET} ${BOLD}Top 5 RAM processes${RESET}        ${DIM}See what's eating your memory right now${RESET}"
  echo -e "  ${CYAN}[4]${RESET} ${BOLD}Free system cache${RESET}          ${DIM}Drop Linux file cache — safe instant RAM recovery${RESET}"
  echo -e "  ${CYAN}[5]${RESET} ${BOLD}pnpm install${RESET}               ${DIM}Run pnpm install in current project folder${RESET}"
  echo -e "  ${CYAN}[6]${RESET} ${BOLD}Show all open ports${RESET}        ${DIM}Quick overview of every listening port${RESET}"
  echo -e "  ${CYAN}[7]${RESET} ${BOLD}Git log (last 10)${RESET}          ${DIM}Show last 10 commits with graph${RESET}"
  echo -e "  ${CYAN}[8]${RESET} ${BOLD}Disk usage${RESET}                 ${DIM}See how full your drives are${RESET}"
  echo -e "  ${CYAN}[0]${RESET} Back\n"
  echo -ne "  ${BOLD}Your choice: ${RESET}"
  read -r QC; QC="${QC//[^0-9]/}"
  echo ""
  case "$QC" in
    1)
      local pid; pid=$(lsof -ti :3000 2>/dev/null | head -1)
      if [ -n "$pid" ]; then
        kill -9 "$pid" 2>/dev/null
        echo -e "  ${GREEN}✓ Port 3000 killed. PID was $pid.${RESET}"
      else
        echo -e "  ${CYAN}  Port 3000 is already free.${RESET}"
      fi ;;
    2) git status 2>/dev/null || echo -e "  ${RED}  Not a git repo.${RESET}" ;;
    3)
      echo -e "  ${BOLD}  Top 5 by RAM:${RESET}\n"
      ps aux --sort=-%mem 2>/dev/null | awk 'NR>1&&NR<=6{printf "  %5s%%  %6.1fMB  PID:%-6s %s\n",$4,$6/1024,$2,$11}' ;;
    4)
      sync && echo 3 | sudo tee /proc/sys/vm/drop_caches > /dev/null
      echo -e "  ${GREEN}✓ System cache freed.${RESET}" ;;
    5) pnpm install ;;
    6)
      echo -e "  ${BOLD}  Listening ports:${RESET}\n"
      ss -tlnp 2>/dev/null | grep LISTEN | awk '{print $4}' | while read -r a; do
        p=$(echo "$a" | rev | cut -d: -f1 | rev)
        [[ "$p" =~ ^[0-9]+$ ]] && echo -e "  ${CYAN}:$p${RESET}"
      done ;;
    7)
      git log --oneline --graph --decorate -10 2>/dev/null || echo -e "  ${RED}  Not a git repo.${RESET}" ;;
    8)
      echo -e "  ${BOLD}  Disk usage:${RESET}\n"
      df -h 2>/dev/null | grep -v tmpfs | grep -v udev | awk 'NR>1{printf "  %-20s %6s / %-8s %s used\n",$1,$3,$2,$5}' ;;
    0) return ;;
    *) echo -e "  ${RED}  Invalid.${RESET}"; sleep 1; return ;;
  esac
  echo ""; pause
}

