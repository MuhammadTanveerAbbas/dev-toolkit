safe_run() {
  local cmd="$1"
  shift
  local args=("$@")
  if ! command -v "$cmd" >/dev/null 2>&1; then
    echo -e "  ${RED}✗ Command not found: $cmd${RESET}"
    return 1
  fi
  "$cmd" "${args[@]}"
}

show_dashboard() {
  local os_badge="[Linux]"
  [ "$OS" = "macos" ] && os_badge="[macOS]"
  [ "$OS" = "windows" ] && os_badge="[Windows]"

  if [ "$OS" = "linux" ]; then
    local total_kb available_kb used_kb used_mb total_mb ram_pct
    total_kb=$(grep MemTotal /proc/meminfo | awk '{print $2}')
    available_kb=$(grep MemAvailable /proc/meminfo | awk '{print $2}')
    used_kb=$(( total_kb - available_kb ))
    used_mb=$(( used_kb / 1024 ))
    total_mb=$(( total_kb / 1024 ))
    ram_pct=$(( used_kb * 100 / total_kb ))

    local swap_total swap_free swap_used swap_pct swap_mb swap_total_mb
    swap_total=$(grep SwapTotal /proc/meminfo | awk '{print $2}')
    swap_free=$(grep SwapFree /proc/meminfo | awk '{print $2}')
    swap_used=$(( swap_total - swap_free ))
    swap_pct=0
    [ "$swap_total" -gt 0 ] && swap_pct=$(( swap_used * 100 / swap_total ))
    swap_mb=$(( swap_used / 1024 ))
    swap_total_mb=$(( swap_total / 1024 ))
  else
    local ram_pct=0 used_mb=0 total_mb=0
    local swap_pct=0 swap_mb=0 swap_total_mb=0
    if [ "$OS" = "macos" ]; then
      local page_size wired active
      page_size=$(vm_stat | awk '/page size of/ {print $8}')
      wired=$(vm_stat | awk '/wired/ {print $4}' | sed 's/\.//')
      active=$(vm_stat | awk '/active/ {print $3}' | sed 's/\.//')
      total_mb=$(( $(sysctl -n hw.memsize) / 1048576 ))
      used_mb=$(( (wired + active) * page_size / 1048576 ))
      [ "$total_mb" -gt 0 ] && ram_pct=$(( used_mb * 100 / total_mb ))
    fi
  fi

  local disk_used disk_total disk_pct
  disk_used=$(df -h / 2>/dev/null | awk 'NR==2{print $3}')
  disk_total=$(df -h / 2>/dev/null | awk 'NR==2{print $2}')
  disk_pct=$(df / 2>/dev/null | awk 'NR==2{gsub(/%/,""); print $5}')

  local cpu_load="N/A"
  [ -f /proc/loadavg ] && cpu_load=$(awk '{print $1}' /proc/loadavg)
  [ "$OS" = "macos" ] && cpu_load=$(sysctl -n vm.loadavg | awk '{print $2}')

  local git_info="not in a repo"
  if git rev-parse --git-dir > /dev/null 2>&1; then
    local branch dirty=""
    branch=$(git branch --show-current 2>/dev/null)
    [ -z "$branch" ] && branch="detached"
    [ -n "$(git status --porcelain 2>/dev/null)" ] && dirty=" ${YELLOW}✎ uncommitted${RESET}"
    git_info="${CYAN}${BOLD}$branch${RESET}$dirty"
  fi

  local inst=0
  for entry in "${TOOLS[@]}"; do
    local c
    c=$(parse_tool "$entry" 3)
    is_installed "$c" && inst=$(( inst + 1 ))
  done

  local now last node_ver pnpm_ver
  now=$(date "+%a %d %b  %H:%M")
  last=$(get_last_used)
  node_ver=$(node -v 2>/dev/null || echo "not found")
  pnpm_ver=$(pnpm -v 2>/dev/null || echo "not found")

  echo ""
  echo -e "  ${CYAN}${BOLD}┌─ SYSTEM DASHBOARD $os_badge ─────────── $now ─┐${RESET}"
  echo ""
  printf "  ${YELLOW}  RAM  ${RESET}  "; draw_bar "$ram_pct" 24; printf "  ${BOLD}%s/%sMB${RESET} ${DIM}%s%%${RESET}\n" "$used_mb" "$total_mb" "$ram_pct"
  if [ "$OS" = "linux" ]; then
    printf "  ${YELLOW}  SWAP ${RESET}  "; draw_bar "$swap_pct" 24; printf "  ${BOLD}%s/%sMB${RESET} ${DIM}%s%%${RESET}\n" "$swap_mb" "$swap_total_mb" "$swap_pct"
  fi
  printf "  ${YELLOW}  DISK ${RESET}  "; draw_bar "${disk_pct:-0}" 24; printf "  ${BOLD}%s/%s${RESET} ${DIM}%s%%${RESET}\n" "$disk_used" "$disk_total" "${disk_pct:-0}"
  echo ""
  echo -e "  ${YELLOW}  CPU  ${RESET}  load: ${BOLD}$cpu_load${RESET}    ${YELLOW}GIT${RESET}   $git_info"
  echo -e "  ${YELLOW}  LAST ${RESET}  $last    ${YELLOW}TOOLS${RESET} ${GREEN}${BOLD}$inst${RESET}${DIM}/${#TOOLS[@]} installed${RESET}"
  echo ""
  echo -e "  ${YELLOW}  NODE ${RESET}  v$node_ver    ${YELLOW}PNPM${RESET}  v$pnpm_ver"
  echo ""
  echo -e "  ${CYAN}${BOLD}└────────────────────────────────────────────────────────────┘${RESET}"
  echo ""
}

show_tool_detail() {
  local entry="$1"
  local name desc cmd category update_cmd docs
  name=$(parse_tool "$entry" 1)
  desc=$(parse_tool "$entry" 2)
  cmd=$(parse_tool "$entry" 3)
  category=$(parse_tool "$entry" 4)
  update_cmd=$(parse_tool "$entry" 5)
  docs=$(parse_tool "$entry" 6)

  local usage_count note status_color status_text tool_path
  usage_count=$(get_usage "$name"); usage_count=${usage_count:-0}
  note=$(get_note "$name")
  tool_path=$(resolve_tool_path "$cmd")
  if [ -n "$tool_path" ]; then
    status_color=$GREEN; status_text="✓ installed"
  else
    status_color=$RED; status_text="✗ not found"
  fi

  clear
  echo ""
  echo -e "  ${CYAN}${BOLD}╔══════════════════════════════════════════════════════╗${RESET}"
  echo -e "  ${CYAN}${BOLD}║  $(echo "$name" | tr '[:lower:]' '[:upper:]')$(printf '%*s' $(( 52 - ${#name} )) "")║${RESET}"
  echo -e "  ${CYAN}${BOLD}╚══════════════════════════════════════════════════════╝${RESET}"
  echo ""
  echo -e "  ${DIM}  $desc${RESET}"
  echo ""
  sep
  echo -e "  ${YELLOW}  Category ${RESET}  $category"
  echo -e "  ${YELLOW}  Command  ${RESET}  ${BOLD}$cmd${RESET}"
  echo -e "  ${YELLOW}  Path     ${RESET}  ${DIM}${tool_path:-not found}${RESET}"
  echo -e "  ${YELLOW}  Status   ${RESET}  ${status_color}${BOLD}$status_text${RESET}"
  echo -e "  ${YELLOW}  Used     ${RESET}  ${BOLD}${usage_count}x${RESET} total"
  echo -e "  ${YELLOW}  Update   ${RESET}  ${DIM}$update_cmd${RESET}"
  echo -e "  ${YELLOW}  Docs     ${RESET}  ${DIM}$docs${RESET}"
  if [ -n "$note" ]; then
    echo -e "  ${YELLOW}  Note     ${RESET}  ${GREEN}\"$note\"${RESET}"
  else
    echo -e "  ${YELLOW}  Note     ${RESET}  ${DIM}none — use [5] to add one${RESET}"
  fi
  sep
  echo ""
  echo -e "  ${CYAN}[1]${RESET} ${BOLD}Run${RESET}    — Launch $name now"
  echo -e "  ${CYAN}[2]${RESET} ${BOLD}Update${RESET} — Run the update command"
  echo -e "  ${CYAN}[3]${RESET} ${BOLD}Remove${RESET} — Uninstall from system"
  echo -e "  ${CYAN}[4]${RESET} ${BOLD}Docs${RESET}   — Open official docs in browser"
  echo -e "  ${CYAN}[5]${RESET} ${BOLD}Note${RESET}   — Save a personal reminder"
  echo -e "  ${CYAN}[0]${RESET} Back"
  echo ""
  echo -ne "  ${BOLD}Your choice: ${RESET}"
  read -r TC
  TC="${TC//[^0-9]/}"

  case "$TC" in
    1)
      track_usage "$name"
      echo -e "\n  ${GREEN}→ Launching ${BOLD}$name${RESET}${GREEN}...${RESET}\n"
      sleep 0.3
      local lp
      lp=$(resolve_tool_path "$cmd")
      if [ -n "$lp" ]; then
        "$lp"
      else
        echo -e "  ${RED}✗ Cannot find $name. Use [a] Add new tool to reinstall.${RESET}"
      fi
      pause ;;
    2)
      echo ""
      if [[ "$update_cmd" == "manual"* ]]; then
        echo -e "  ${YELLOW}  Manually managed tool.${RESET}"
        echo -e "  ${DIM}  Re-download from: $docs${RESET}"
        [ "$name" = "cursor" ] && echo -e "  ${DIM}  Or: cursor-reset → option 5${RESET}"
      else
        echo -e "  ${YELLOW}→ $update_cmd${RESET}\n"
        local upd_cmd upd_args
        read -r upd_cmd upd_args <<< "$update_cmd"
        safe_run "$upd_cmd" $upd_args
        echo -e "\n  ${GREEN}${BOLD}✓ Done.${RESET}"
      fi
      pause ;;
    3)
      echo -e "\n  ${RED}${BOLD}  Remove $name permanently?${RESET}"
      echo -ne "  Type YES to confirm: "
      read -r RC
      if [ "$RC" = "YES" ]; then
        local rp; rp=$(resolve_tool_path "$cmd")
        if [[ "$update_cmd" == *"pnpm"* ]]; then pnpm remove -g "$name" 2>/dev/null
        elif [[ "$update_cmd" == *"npm"* ]]; then npm uninstall -g "$name" 2>/dev/null
        elif [[ "$update_cmd" == *"apt"* ]]; then sudo apt remove "$name" -y 2>/dev/null
        elif [ -n "$rp" ]; then sudo rm -f "$rp" "/usr/local/bin/$name" 2>/dev/null
        else sudo rm -f "/usr/local/bin/$name" 2>/dev/null; fi
        echo -e "  ${GREEN}✓ Removed.${RESET}"
      else
        echo -e "  ${CYAN}  Cancelled.${RESET}"
      fi
      pause ;;
    4)
      open_url "$docs"
      pause ;;
    5)
      echo ""
      local cn; cn=$(get_note "$name")
      [ -n "$cn" ] && echo -e "  ${DIM}  Current: $cn${RESET}\n"
      echo -ne "  Your note for $name: "
      read -r NN
      if [ -n "$NN" ]; then
        save_note "$name" "$NN"
        echo -e "  ${GREEN}✓ Saved.${RESET}"
      else
        echo -e "  ${CYAN}  No changes.${RESET}"
      fi
      pause ;;
    0) return ;;
    *) echo -e "  ${RED}  Invalid.${RESET}"; sleep 1 ;;
  esac
}

health_check() {
  clear; echo ""
  echo -e "  ${GREEN}${BOLD}╔══════════════════════════════════════════════════════╗${RESET}"
  echo -e "  ${GREEN}${BOLD}║  HEALTH CHECK                                        ║${RESET}"
  echo -e "  ${GREEN}${BOLD}╚══════════════════════════════════════════════════════╝${RESET}"
  echo -e "  ${DIM}  Scanning all ${#TOOLS[@]} registered tools...${RESET}\n"
  local healthy=0 broken=0 broken_list=()
  for entry in "${TOOLS[@]}"; do
    local name cmd
    name=$(parse_tool "$entry" 1)
    cmd=$(parse_tool "$entry" 3)
    printf "  Checking %-22s" "$name..."
    sleep 0.05
    if is_installed "$cmd"; then
      echo -e " ${GREEN}${BOLD}✓ OK${RESET}"; healthy=$(( healthy + 1 ))
    else
      echo -e " ${RED}${BOLD}✗ MISSING${RESET}"; broken=$(( broken + 1 )); broken_list+=("$name")
    fi
  done
  echo ""; sep
  echo -e "  ${GREEN}  Healthy : ${BOLD}$healthy / ${#TOOLS[@]}${RESET}"
  if [ "$broken" -gt 0 ]; then
    echo -e "  ${RED}  Missing : ${BOLD}$broken${RESET}\n"
    for t in "${broken_list[@]}"; do echo -e "  ${DIM}    → $t${RESET}"; done
    echo -e "\n  ${DIM}  Use [a] Add new tool to reinstall missing ones.${RESET}"
  else
    echo -e "  ${GREEN}${BOLD}  ✓ All tools installed and working.${RESET}"
  fi
  echo ""; pause
}

