      h|H) health_check ;;
      u|U) update_all ;;
      a|A) add_new_tool ;;
      n|N) show_all_notes ;;
      s|S) show_stats ;;
      q|Q) quick_actions ;;
      0)   echo -e "\n  ${CYAN}  Bye.${RESET}\n"; exit 0 ;;
      *)   echo -e "  ${RED}  Invalid.${RESET}"; sleep 1 ;;
    esac
  fi
}

